rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function for admin check using custom claims
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Helper: Size limits in bytes
    function maxDishImageSize() {
      return 300 * 1024;  // 300KB
    }

    function maxRiderPhotoSize() {
      return 300 * 1024;  // 300KB
    }

    // Helper: Restrict outlet wildcard to known outlets
    function isOutletRestricted(userOutlet, resourceOutlet) {
      return (request.auth != null && isAdmin()) || userOutlet == resourceOutlet;
    }

    // --------------------------------------------
    // ADMINS: Full access for administrators
    // --------------------------------------------
    match /admins/{adminId}/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    // --------------------------------------------
    // RIDERS: Admin write, Self/Admin read, Self photo write (300KB limit)
    // --------------------------------------------
    match /riders/{riderId}/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == riderId);
      allow write: if isAdmin();
      allow write: if request.auth != null 
                   && request.auth.uid == riderId
                   && request.resource.size < maxRiderPhotoSize()
                   && request.resource.contentType.matches('image/.*');
    }
    
    // --------------------------------------------
    // BOT: WhatsApp order/status images (5MB limit)
    // --------------------------------------------
    match /bot/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if request.auth != null 
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // --------------------------------------------
    // OUTLET DISHES: Authenticated read, admin write (300KB limit)
    // --------------------------------------------
    match /{outlet}/dishes/{dishId}/{allPaths=**} {
      allow read: if request.auth != null && isOutletRestricted(request.auth.token.outlet, outlet);
      allow write: if isAdmin() 
                   && request.resource.size < maxDishImageSize()
                   && request.resource.contentType.matches('image/.*');
    }
    
    // --------------------------------------------
    // OUTLET CATEGORIES: Authenticated read, admin write (300KB limit)
    // --------------------------------------------
    match /{outlet}/categories/{catId}/{allPaths=**} {
      allow read: if request.auth != null && isOutletRestricted(request.auth.token.outlet, outlet);
      allow write: if isAdmin()
                   && request.resource.size < maxDishImageSize()
                   && request.resource.contentType.matches('image/.*');
    }
    
    // --------------------------------------------
    // RECEIPTS: Admin read/write
    // --------------------------------------------
    match /receipts/{orderId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // --------------------------------------------
    // USER PROFILES: Admin write, Self/Admin read
    // --------------------------------------------
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == uid);
      allow write: if isAdmin();
    }

    // --------------------------------------------
    // DEFAULT: Deny all other paths
    // --------------------------------------------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
