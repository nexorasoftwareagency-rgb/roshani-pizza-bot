rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // General rule: Authentication required for reading
      allow read: if request.auth != null;
      
      // Strict write rules: User-prefixed paths and size/type validation
      allow write: if request.auth != null 
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (request.auth.token.admin == true || allPaths.startsWith('users/' + request.auth.uid));
    }
  }
}
