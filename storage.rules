rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Global read: Only admins can read everything. 
      // Users can only read if it's their own path.
      allow read: if request.auth != null 
                   && (request.auth.token.admin == true || allPaths.startsWith('users/' + request.auth.uid));
      
      // Write rules: Only admins or owner of the path.
      allow write: if request.auth != null 
                   && (request.auth.token.admin == true || allPaths.startsWith('users/' + request.auth.uid))
                   && (request.resource == null || (
                     request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*')
                   ));
    }
  }
}
