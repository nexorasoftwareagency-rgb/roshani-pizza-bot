/* app.js: Add touch event listeners to main scroll container */
document.addEventListener('touchstart', (e) => {
  if (window.scrollY === 0) {
    startY = e.touches[0].clientY;
  }
}, { passive: true });

document.addEventListener('touchmove', (e) => {
  if (startY && window.scrollY === 0) {
    const diff = e.touches[0].clientY - startY;
    if (diff > 80 && !isPullToRefreshActive) {
      isPullToRefreshActive = true;
      showPullToRefreshUI(); // Show spinner
    }
  }
}, { passive: true });

document.addEventListener('touchend', () => {
  if (isPullToRefreshActive) {
    refreshAllData().finally(() => {
      isPullToRefreshActive = false;
      hidePullToRefreshUI();
    });
  }
  startY = 0;
});

/* Add UI functions */
function showPullToRefreshUI() {
  const pullEl = document.getElementById('pull-to-refresh');
  if (pullEl) pullEl.classList.add('visible');
}

function hidePullToRefreshUI() {
  const pullEl = document.getElementById('pull-to-refresh');
  if (pullEl) pullEl.classList.remove('visible');
}

