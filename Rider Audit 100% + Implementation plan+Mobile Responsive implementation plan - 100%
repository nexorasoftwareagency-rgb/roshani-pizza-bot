### 2.5 Swipe-to-Accept/Decline Orders

**Problem:** No quick action gestures on order cards.

**Solution:**

```javascript
/* app.js: Add to order card creation (renderOrderCard function) */
function renderOrderCard(order, outlet) {
  const card = document.createElement('div');
  card.className = 'order-card swipeable';
  card.dataset.orderId = order.id;
  
  // Touch handling
  let touchStartX = 0;
  let touchEndX = 0;
  
  card.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
    touchEndX = 0;
  }, { passive: true });
  
  card.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe(card, order);
  }, { passive: true });
  
  function handleSwipe(card, order) {
    const diff = touchStartX - touchEndX;
    const threshold = 80; // px
    
    if (Math.abs(diff) > threshold) {
      if (diff > 0) {
        // Swipe left → Accept
        acceptOrder(order.id, outlet);
        card.style.transition = 'transform 0.3s';
        card.style.transform = 'translateX(-100%)';
      } else {
        // Swipe right → Decline
        declineOrder(order.id, outlet);
        card.style.transition = 'transform 0.3s';
        card.style.transform = 'translateX(100%)';
      }
      
      // Remove card after animation
      setTimeout(() => card.remove(), 300);
    } else {
      // Reset if not enough distance
      card.style.transition = 'transform 0.2s';
      card.style.transform = 'translateX(0)';
    }
  }
  
  // ... rest of card creation
  return card;
}
```

