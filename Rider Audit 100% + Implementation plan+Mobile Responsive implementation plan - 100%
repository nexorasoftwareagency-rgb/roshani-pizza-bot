### 2.3 Fix Map Resize on Orientation Change

**Problem:** Map container has fixed height; orientation change breaks view.

**Solution:**

```javascript
/* app.js: Add after line 1405 map resize logic */
let resizeTimeout;
window.addEventListener('orientationchange', () => {
  clearTimeout(resizeTimeout);
  // Wait for orientation animation to finish
  resizeTimeout = setTimeout(() => {
    if (riderMap) {
      riderMap.invalidateSize();
      riderMap.invalidateSize(); // Call twice for Leaflet quirk
      // Re-center on rider location if available
      if (window.riderLocation) {
        riderMap.setView([window.riderLocation.lat, window.riderLocation.lng], 14);
      }
    }
  }, 500); // 500ms after orientation change
});

/* Also handle resize event (desktop browser window resize) */
window.addEventListener('resize', debounce(() => {
  if (riderMap) {
    riderMap.invalidateSize();
  }
}, 250));

// Add debounce utility at top of app.js if not exists
function debounce(fn, delay) {
  let timer;
  return () => {
    clearTimeout(timer);
    timer = setTimeout(fn, delay);
  };
}
```

**Validation:** Rotate phone from portrait→landscape→portrait; map always fills container, markers visible.

