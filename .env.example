# Roshani ERP — Environment Variables
# Copy to .env and fill in values (bot only; admin/rider use Firebase config)

# Outlet selection: "pizza" or "cake"
OUTLET=pizza

# Redis connection (optional — falls back to in-memory cache)
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=rediss://your-elasticache-endpoint:6379

# Node environment
NODE_ENV=development
