{
  "rules": {
    "admins": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth.token.admin === true"
    },
    "migrationStatus": {
      ".read": "auth != null",
      ".write": "auth.token.admin === true"
    },
    "riders": {
      ".read": "auth != null",
      "$riderId": {
        ".read": "auth != null && (auth.token.admin === true || auth.uid == $riderId)",
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)",
        ".validate": "newData.hasChildren(['name', 'email'])"
      }
    },
    "riderStats": {
      ".read": "auth != null",
      "$riderId": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)"
      }
    },
    "botStatus": {
      ".read": "auth != null",
      ".write": "auth.token.admin === true"
    },
    "logs": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null"
    },

    "$outlet": {
      "settings": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "appConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "uiConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "orders": {
        ".read": "(auth != null && auth.token.admin === true) || (auth != null && query.orderByChild == 'assignedRider')",
        "$orderId": {
          ".read": "auth != null && (auth.token.admin === true || data.child('assignedRider').val() == auth.token.email || data.child('whatsappNumber').val() == auth.token.whatsapp)",
          ".write": "auth != null && (auth.token.admin === true || !data.exists() || data.child('assignedRider').val() == auth.token.email)",
          ".validate": "newData.hasChild('status')"
        }
      },
      "categories": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "dishes": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "feedbacks": {
        ".read": "auth != null && auth.token.admin === true",
        "$feedbackId": {
          ".write": "auth != null && !data.exists()"
        }
      },
      "inventory": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "liveTracker": {
        "$riderId": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)"
        }
      },
      "metadata": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
      },
      "lostSales": {
        ".read": "auth != null && auth.token.admin === true",
        ".write": "auth != null"
      }
    },

    
    "settings": { ".read": "auth != null", ".write": "auth.token.admin === true" },
    "appConfig": { ".read": "auth != null", ".write": "auth.token.admin === true" },
    "uiConfig": { ".read": "auth != null", ".write": "auth.token.admin === true" },
    "orders": {
      ".read": "(auth != null && auth.token.admin === true) || (auth != null && query.orderByChild == 'assignedRider')",
      "$orderId": {
        ".read": "auth != null && (auth.token.admin === true || data.child('assignedRider').val() == auth.token.email || data.child('whatsappNumber').val() == auth.token.whatsapp)",
        ".write": "auth != null && (auth.token.admin === true || !data.exists())"
      }
    },
    "categories": { ".read": "auth != null", ".write": "auth.token.admin === true" }
  }
}
