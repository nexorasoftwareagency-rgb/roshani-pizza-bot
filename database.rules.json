{
  "rules": {
    "admins": {
      ".indexOn": [
        "email"
      ],
      // Bootstrap: Allow any authenticated user with admin claim or matching bootstrap email to read
      ".read": "auth != null && (auth.token.admin === true || root.child('admins/a1/email').val() == auth.token.email || root.child('admins/a2/email').val() == auth.token.email)",
      ".write": "auth != null && (!data.exists() || root.child('admins/' + auth.uid).exists())",
      "$adminId": {
        ".read": "auth != null && (auth.uid == $adminId || root.child('admins/' + auth.uid).exists())",
        ".write": "auth != null && (!data.exists() || root.child('admins/' + auth.uid).exists() || auth.uid == $adminId)",
        ".validate": "newData.hasChildren(['name', 'email'])"
      }
    },
    "riderStats": {
      // Admins can read/write all, riders can read/write their own stats (for increments)
      ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
      ".write": "auth != null && root.child('admins/' + auth.uid).exists()",
      "$riderId": {
        ".read": "auth != null && (root.child('admins/' + auth.uid).exists() || auth.uid == $riderId)",
        ".write": "auth != null && (root.child('admins/' + auth.uid).exists() || auth.uid == $riderId)"
      }
    },
    "riders": {
      ".indexOn": [
        "email"
      ],
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())",
        ".write": "auth != null && (root.child('admins/' + auth.uid).exists() || (auth.uid == $uid && newData.child('email').val() == data.child('email').val() && newData.child('name').val() == data.child('name').val() && newData.child('aadharNo').val() == data.child('aadharNo').val() && newData.child('outlet').val() == data.child('outlet').val() && newData.child('id').val() == data.child('id').val()))",
        "notifications": {
          ".indexOn": [
            "timestamp"
          ],
          ".read": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())",
          ".write": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())",
          "$notifId": {
            ".validate": "newData.hasChildren(['title', 'body', 'timestamp'])"
          }
        },
        "status": {
          ".write": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())"
        },
        "fcmToken": {
          ".write": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())"
        },
        "lastSeen": {
          ".write": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())"
        },
        "profilePhoto": {
          ".write": "auth != null && (auth.uid == $uid || root.child('admins/' + auth.uid).exists())"
        }
      }
    },
    "logs": {
      ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
      ".write": "auth != null && root.child('admins/' + auth.uid).exists()",
      "riderErrors": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "bot": {
      // Internal bot config - restricted to admins only
      ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
      ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
    },
    "$outlet": {
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "appConfig": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "orders": {
        ".indexOn": [
          "assignedRider",
          "status",
          "whatsappNumber"
        ],
        // Strict read: Admins see all, Riders only see unassigned or their own
        // Removed status query to prevent order enumeration across all outlets
        ".read": "auth != null && (root.child('admins/' + auth.uid).exists() || query.orderByChild == 'assignedRider' && query.equalTo == auth.token.email)",
        "$orderId": {
          ".read": "auth != null && (root.child('admins/' + auth.uid).exists() || !data.child('assignedRider').exists() || data.child('assignedRider').val() == auth.token.email)",
          ".write": "auth != null && (root.child('admins/' + auth.uid).exists() || (data.child('assignedRider').val() == auth.token.email || !data.child('assignedRider').exists()))",
          ".validate": "newData.hasChildren(['status', 'total', 'items'])",
          // Non-admin riders can only update assignedRider field
          "assignedRider": {
            ".validate": "!root.child('admins/' + auth.uid).exists() || newData.val() == data.val() || (auth.token.email == newData.val() && !data.exists())"
          }
        }
      },
      "categories": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "dishes": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "liveTracker": {
        ".read": "auth != null",
        "$riderId": {
          ".write": "auth != null && (root.child('admins/' + auth.uid).exists() || auth.uid == $riderId)"
        }
      },
      "otpAttempts": {
        "$orderId": {
          // Only assigned rider or admin can read/write failure counts
          ".read": "auth != null && (root.child('admins/' + auth.uid).exists() || root.child($outlet + '/orders/' + $orderId + '/assignedRider').val() == auth.token.email)",
          ".write": "auth != null && (root.child('admins/' + auth.uid).exists() || root.child($outlet + '/orders/' + $orderId + '/assignedRider').val() == auth.token.email)"
        }
      },
      "lostSales": {
        ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "customers": {
        ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
        ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
      },
      "feedbacks": {
        ".read": "auth != null && root.child('admins/' + auth.uid).exists()",
        ".write": "auth != null"
      }
    }
  }
}