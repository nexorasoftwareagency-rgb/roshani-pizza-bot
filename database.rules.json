{
  "rules": {
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)",
        ".validate": "newData.hasChildren(['email', 'outlet'])"
      }
    },
    "riders": {
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid == $uid || root.child('admins').child(auth.uid).exists())"
      },
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["email"]
    },
    "riderStats": {
      "$riderId": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || auth.uid == $riderId)"
      }
    },
    "logs": {
      "audit": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
        "$logId": {
          ".validate": "newData.hasChildren(['action', 'timestamp', 'adminEmail']) && !data.exists()"
        }
      },
      "lostSales": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      },
      "riderErrors": {
        "$riderId": {
          ".read": "auth != null && (auth.uid == $riderId || root.child('admins').child(auth.uid).exists())",
          ".write": "auth != null && auth.uid == $riderId"
        }
      }
    },
    "bot": {
       ".read": "auth != null",
       ".write": "auth != null"
    },
    "migrationStatus": {
       ".read": "auth != null",
       ".write": "auth != null"
    },
    "pizza": {
      "orders": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('riders').child(auth.uid).exists() && query.orderByChild == 'assignedRider' && (query.equalTo == null || query.equalTo == root.child('riders').child(auth.uid).child('email').val().toLowerCase())))",
        ".indexOn": ["createdAt", "status", "riderId", "assignedRider"],
        "$orderId": {
          ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || !data.child('assignedRider').exists() || data.child('assignedRider').val().toLowerCase() == root.child('riders').child(auth.uid).child('email').val().toLowerCase())",
          ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('riders').child(auth.uid).exists() && (!data.child('riderId').exists() || data.child('riderId').val() == auth.uid)))",
          ".validate": "newData.hasChildren(['items', 'total', 'status', 'createdAt']) && (root.child('admins').child(auth.uid).exists() || (newData.child('items').val() == data.child('items').val() && newData.child('total').val() == data.child('total').val()))"
        }
      },
      "dishes": {
        ".read": "true",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "Menu": {
        ".read": "true",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "categories": {
        ".read": "true",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "lostSales": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      },
      "customers": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('riders').child(auth.uid).exists() || auth != null)"
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "uiConfig": {
        ".read": "true",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },
    "cake": {
      "orders": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('riders').child(auth.uid).exists() && query.orderByChild == 'assignedRider' && (query.equalTo == null || query.equalTo == root.child('riders').child(auth.uid).child('email').val().toLowerCase())))",
        ".indexOn": ["createdAt", "status", "riderId", "assignedRider"],
        "$orderId": {
          ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || !data.child('assignedRider').exists() || data.child('assignedRider').val().toLowerCase() == root.child('riders').child(auth.uid).child('email').val().toLowerCase())",
          ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('riders').child(auth.uid).exists() && (!data.child('riderId').exists() || data.child('riderId').val() == auth.uid)))",
          ".validate": "newData.hasChildren(['items', 'total', 'status', 'createdAt']) && (root.child('admins').child(auth.uid).exists() || (newData.child('items').val() == data.child('items').val() && newData.child('total').val() == data.child('total').val()))"
        }
      },
      "dishes": {
        ".read": "true",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "categories": {
        ".read": "true",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      },
      "lostSales": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      },
      "customers": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('riders').child(auth.uid).exists() || auth != null)"
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins').child(auth.uid).child('role').val() == 'Super Admin' || root.child('admins').child(auth.uid).child('isSuper').val() == true)"
      }
    }
  }
}