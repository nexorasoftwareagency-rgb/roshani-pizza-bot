{
  "rules": {
    "orders": {
      // Admin can see everything. Riders can only see orders assigned to them or unassigned.
      ".read": "(auth != null && auth.token.admin === true) || (auth != null && query.orderByChild == 'assignedRider')",
      "$orderId": {
        ".read": "auth != null && (auth.token.admin === true || data.child('assignedRider').val() == auth.token.email || data.child('whatsappNumber').val() == auth.token.whatsapp)",
        ".write": "auth != null && (auth.token.admin === true || !data.exists())",
        ".validate": "newData.hasChildren(['total', 'items', 'status'])"
      }
    },
    "dishes": {
      ".read": "auth != null",
      ".write": "auth.token.admin === true"
    },
    "riderStats": {
      ".read": "auth != null",
      "$riderId": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)"
      }
    },
    "riders": {
      // Only admins should see the list of all riders. Riders can only see their own profile.
      ".read": "auth != null && auth.token.admin === true",
      "$riderId": {
        ".read": "auth != null && (auth.token.admin === true || auth.uid == $riderId)",
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)",
        ".validate": "newData.hasChildren(['name', 'email', 'outlet'])"
      }
    },
    "feedbacks": {
      ".read": "auth != null && auth.token.admin === true",
      "$feedbackId": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "customers": {
      // Customers node is PII, only admins read/write
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth.token.admin === true"
    },
    "appConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "uiConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "settings": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "admins": {
        ".read": "auth != null && auth.token.admin === true",
        ".write": "auth.token.admin === true"
    }
  }
}
