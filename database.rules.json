{
  "rules": {
    "orders": {
      ".read": "auth != null",
      ".write": "auth != null && (data.child('ownerId').val() == auth.uid || auth.token.admin === true || !data.exists())",
      "$orderId": {
        ".validate": "newData.hasChildren(['total', 'items', 'status'])"
      }
    },
    "dishes": {
      ".read": "auth != null",
      ".write": "auth.token.admin === true"
    },
    "riderStats": {
      ".read": "auth != null",
      "$riderId": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)"
      }
    },
    "riders": {
      ".read": "auth != null",
      "$riderId": {
        ".write": "auth != null && (auth.token.admin === true || auth.uid == $riderId)",
        ".validate": "newData.hasChildren(['name', 'email', 'outlet'])"
      }
    },
    "feedbacks": {
      ".read": "auth != null",
      "$feedbackId": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "customers": {
      ".read": "auth != null",
      ".write": "auth.token.admin === true"
    },
    "appConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "uiConfig": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "settings": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    "admins": {
        ".read": "auth != null",
        ".write": "auth.token.admin === true"
    },
    ".read": false,
    ".write": false
  }
}
