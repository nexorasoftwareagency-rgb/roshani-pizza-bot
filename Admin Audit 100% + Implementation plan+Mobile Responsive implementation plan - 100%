### 2.3 Implement Pull-to-Refresh (Optional)

**Not critical for admin**, but nice-to-have for Dashboard/Live Orders.

**JS** (append to `app.js` after line 232):

```javascript
// Pull-to-refresh for main content
let ptrStartY = 0;
let ptrActive = false;

document.addEventListener('touchstart', (e) => {
  if (window.scrollY === 0) {
    ptrStartY = e.touches[0].clientY;
  }
}, { passive: true });

document.addEventListener('touchmove', (e) => {
  if (ptrStartY && window.scrollY === 0) {
    const diff = e.touches[0].clientY - ptrStartY;
    if (diff > 80 && !ptrActive) {
      ptrActive = true;
      showPullToRefresh();
    }
  }
}, { passive: true });

document.addEventListener('touchend', () => {
  if (ptrActive) {
    ptrActive = false;
    hidePullToRefresh();
    // Refresh current tab's data
    const activeTab = window.currentActiveTab;
    if (activeTab === 'dashboard') loadDashboard();
    if (activeTab === 'orders') renderOrdersSnapshot();
    // ... etc
  }
  ptrStartY = 0;
});

function showPullToRefresh() {
  const el = document.getElementById('ptr-indicator') || (() => {
    const div = document.createElement('div');
    div.id = 'ptr-indicator';
    div.innerHTML = '<i data-lucide="refresh-cw"></i> Pulling...';
    document.body.appendChild(div);
    lucide.createIcons();
    return div;
  })();
  el.style.display = 'block';
}

function hidePullToRefresh() {
  const el = document.getElementById('ptr-indicator');
  if (el) el.style.display = 'none';
}
```

